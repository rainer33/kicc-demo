#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
ENV_FILE="${ROOT_DIR}/.env.local"

if [[ -f "${ENV_FILE}" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "${ENV_FILE}"
  set +a
fi

if [[ -z "${ADMIN_TOKEN:-}" ]]; then
  ADMIN_TOKEN="dev-$(cat /proc/sys/kernel/random/uuid | tr -d '-')"
  export ADMIN_TOKEN
  echo "ADMIN_TOKEN not set. Using generated dev token: ${ADMIN_TOKEN}"
fi
cd "${ROOT_DIR}/backend"
./gradlew bootRun
